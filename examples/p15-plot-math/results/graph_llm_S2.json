{
  "nodes": [
    {
      "id": 1,
      "event": "他帮她拉开门",
      "actor": "他",
      "type": "action",
      "text_window": "“这个酒吧我经常带朋友来，每个朋友都很喜欢这个暗黑格调。”他帮她拉开门。"
    },
    {
      "id": 2,
      "event": "他指着靠里的桌子",
      "actor": "他",
      "type": "action",
      "text_window": "他指着靠里的一个桌子，“这个桌子我一个人来的时候常坐。”"
    },
    {
      "id": 3,
      "event": "陆知微说坐这个桌子",
      "actor": "陆知微",
      "type": "action",
      "text_window": "“那我们还坐这个。”陆知微说。"
    },
    {
      "id": 4,
      "event": "他和店员小哥哥挥手",
      "actor": "他",
      "type": "action",
      "text_window": "一遍说着话，他一边和店员小哥哥挥手，“你家老板娘又不在啊。”"
    },
    {
      "id": 5,
      "event": "店员小哥哥点头",
      "actor": "店员小哥哥",
      "type": "action",
      "text_window": "店员小哥哥点了点头。"
    },
    {
      "id": 6,
      "event": "他说坐外面",
      "actor": "他",
      "type": "action",
      "text_window": "“咱们坐外面这个，那张桌子有点小。”"
    },
    {
      "id": 7,
      "event": "店员小哥哥递菜单",
      "actor": "店员小哥哥",
      "type": "action",
      "text_window": "店员小哥哥递过来一个菜单。"
    },
    {
      "id": 8,
      "event": "她悄悄说店员小哥哥帅",
      "actor": "她",
      "type": "action",
      "text_window": "“这个店员小哥哥有点腼腆又帅帅的。”等店员走后，她悄悄和他说。"
    },
    {
      "id": 9,
      "event": "他心里有点醋",
      "actor": "他",
      "type": "internal",
      "text_window": "他的心里有点醋，嘴上却说，“确实确实。我也觉得他帅且腼腆。”"
    },
    {
      "id": 10,
      "event": "他翻菜单介绍",
      "actor": "他",
      "type": "action",
      "text_window": "他翻着菜单给她介绍，“推荐你试试这个，妹妹说紫色很有韵味，很好喝的小甜酒。”"
    },
    {
      "id": 11,
      "event": "她要点酒",
      "actor": "她",
      "type": "action",
      "text_window": "“那我要一个，老板不能喝，我试试看为啥我不能喝。”"
    },
    {
      "id": 12,
      "event": "喝了点酒",
      "actor": "他",
      "type": "action",
      "text_window": "喝了点酒以后，他的话少了点。“我开始醉了。”"
    },
    {
      "id": 13,
      "event": "她问他何时开始喝酒",
      "actor": "她",
      "type": "action",
      "text_window": "“我听说你在学校的时候滴酒不沾的，什么时候开始喝的？”她问。"
    },
    {
      "id": 14,
      "event": "他说今年开始尝试鸡尾酒",
      "actor": "他",
      "type": "action",
      "text_window": "“今年刚开始尝试鸡尾酒，可惜酒量很差，每次一小杯，喝着好玩儿。”他说。"
    },
    {
      "id": 15,
      "event": "回忆那次他一杯就醉",
      "actor": "他",
      "type": "internal",
      "text_window": "那次他一杯就醉了。"
    },
    {
      "id": 16,
      "event": "醉酒后林远亭压不住话",
      "actor": "林远亭",
      "type": "internal",
      "text_window": "醉酒以后的林远亭格外压不住话。"
    },
    {
      "id": 17,
      "event": "xx问是否喜欢她",
      "actor": "xx",
      "type": "action",
      "text_window": "“你喜不喜欢她？”xx问。"
    },
    {
      "id": 18,
      "event": "林远亭说喜欢十年",
      "actor": "林远亭",
      "type": "action",
      "text_window": "“喜欢，很喜欢，喜欢了十年。喜欢地想要发疯。”林远亭说。"
    },
    {
      "id": 19,
      "event": "林远亭补充可能是执念",
      "actor": "林远亭",
      "type": "action",
      "text_window": "“但可能更多是执念。”林远亭补充道。"
    },
    {
      "id": 20,
      "event": "xx说上就完了",
      "actor": "xx",
      "type": "action",
      "text_window": "“管它是不是执念，上就完了啊！”"
    },
    {
      "id": 21,
      "event": "林远亭担心伤害对方",
      "actor": "林远亭",
      "type": "action",
      "text_window": "“可我担心会伤害对方。”林远亭说。"
    },
    {
      "id": 22,
      "event": "xx说他在伤害自己",
      "actor": "xx",
      "type": "action",
      "text_window": "“你现在正在伤害自己。”"
    },
    {
      "id": 23,
      "event": "他从回忆中抽出",
      "actor": "他",
      "type": "internal",
      "text_window": "他从回忆中抽出，望向眼前的人。"
    },
    {
      "id": 24,
      "event": "她好像也醉了",
      "actor": "她",
      "type": "internal",
      "text_window": "她好像也醉了。酒量和自己一样地不好。"
    },
    {
      "id": 25,
      "event": "陆知微回忆吃饭时他在隔壁桌",
      "actor": "陆知微",
      "type": "internal",
      "text_window": "“我还记得有次吃饭的时候，你就在隔壁桌。当时我看你喝的是果粒橙。”陆知微回忆道。"
    },
    {
      "id": 26,
      "event": "他说那阵子养胃",
      "actor": "他",
      "type": "action",
      "text_window": "“那阵子养胃，可乐雪碧都不敢喝的。”"
    },
    {
      "id": 27,
      "event": "他想起什么",
      "actor": "他",
      "type": "internal",
      "text_window": "他顿了顿，突然想起来了什么。"
    },
    {
      "id": 28,
      "event": "他确认是大四同学聚餐",
      "actor": "他",
      "type": "action",
      "text_window": "“你是说我大四开学的同学聚餐吗？我记得当时你和你闺蜜和室友在旁边好像是给谁过生日。”"
    },
    {
      "id": 29,
      "event": "陆知微说那次是室友生日",
      "actor": "陆知微",
      "type": "action",
      "text_window": "“那次是我室友 xx 的生日。我带了我闺蜜 xx 给她们认识。”"
    },
    {
      "id": 30,
      "event": "他说只注意到她",
      "actor": "他",
      "type": "action",
      "text_window": "“那天我只注意到了你，不太记得其他人了。只记得是白色的衬衣，黑色的裤子，显得腿长。你本来也苗条。”"
    },
    {
      "id": 31,
      "event": "她问是否一直记着她",
      "actor": "她",
      "type": "action",
      "text_window": "“所以，你一直都记着我？”她的眼神闪烁。"
    },
    {
      "id": 32,
      "event": "他说一直记着",
      "actor": "他",
      "type": "action",
      "text_window": "“当然，一直记着。”"
    },
    {
      "id": 33,
      "event": "陆知微难过说错过十年",
      "actor": "陆知微",
      "type": "internal",
      "text_window": "“如果我们互相都记着对方十年，那么我们错过的十年要算什么呢…”陆知微有点难过。"
    },
    {
      "id": 34,
      "event": "酒吧音乐切换到《原谅》",
      "actor": "外部",
      "type": "external",
      "text_window": "酒吧的音乐切换到了张玉华的《原谅》：“原谅被你带走的永远，时钟就快要走到明天，痛会随着时间好了一点…”"
    },
    {
      "id": 35,
      "event": "林远亭沉浸在音乐里",
      "actor": "林远亭",
      "type": "internal",
      "text_window": "醉酒了的林远亭又一次卸下了紧张和防备。他沉浸在音乐里不出声。"
    },
    {
      "id": 36,
      "event": "他给出回答",
      "actor": "他",
      "type": "action",
      "text_window": "良久，他给出了回答。"
    },
    {
      "id": 37,
      "event": "他说我们都原谅自己",
      "actor": "他",
      "type": "action",
      "text_window": "“我们都原谅自己。”"
    },
    {
      "id": 38,
      "event": "陆知微鼓起勇气问是否喜欢她",
      "actor": "陆知微",
      "type": "action",
      "text_window": "陆知微鼓起勇气，问出了一直想问的话：“你喜不喜欢我？”"
    },
    {
      "id": 39,
      "event": "林远亭说喜欢十年",
      "actor": "林远亭",
      "type": "action",
      "text_window": "“喜欢，很喜欢，喜欢了十年。喜欢地想要发疯。”林远亭说。"
    },
    {
      "id": 40,
      "event": "她问是否愿意在一起",
      "actor": "她",
      "type": "action",
      "text_window": "“那你愿不愿意和我在一起。”她问。"
    },
    {
      "id": 41,
      "event": "他回应愿意",
      "actor": "他",
      "type": "action",
      "text_window": "“愿意。一直都愿意。”他回应。"
    },
    {
      "id": 42,
      "event": "她说你不许离开我",
      "actor": "她",
      "type": "action",
      "text_window": "“你不许离开我。”她的声音有点颤抖。"
    },
    {
      "id": 43,
      "event": "他说离不开也不愿意离开",
      "actor": "他",
      "type": "action",
      "text_window": "“我离不开你，也不愿意离开你。”他也是。"
    }
  ],
